{
  "name": "codexthon",
  "version": "0.0.1",
  "description": "Self-hosted operations system for Codex hackathons",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/vltansky/codexthon.git"
  },
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "deploy": "base44 deploy",
    "test": "node --experimental-strip-types --test src/*.test.ts",
    "test:mcp": "deno test --node-modules-dir=auto base44/functions/admin-mcp/server.test.ts base44/functions/portal-mcp/server.test.ts",
    "pretypecheck": "npx base44 types generate",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.mcp.json",
    "prebuild": "npx base44 types generate",
    "build": "tsc -p tsconfig.json && vite build"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "base44": "^0.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "zod": "4.4.3"
  },
  "dependencies": {
    "@base44/sdk": "^0.8.39",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "onnxruntime-web": "1.20.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.3"
  }
}
