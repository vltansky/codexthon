{
  "compilerOptions": {
    "paths": {
      "@/*": ["./app/*"]
    },
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist-worker",
    "rootDir": "src",
    "rewriteRelativeImportExtensions": true,
    "types": [
      "node"
    ],
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "src/**/*.ts",
    "base44/.types/*.d.ts"
  ]
}
