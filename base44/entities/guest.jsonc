{
  "name": "Guest",
  "description": "Legacy synthetic check-in POC data retained until dashboard cleanup",
  "type": "object",
  "properties": {
    "guest_key": { "type": "string" },
    "display_name": { "type": "string" },
    "registration_status": { "type": "string" },
    "check_in_status": {
      "type": "string",
      "enum": ["checked_in", "not_checked_in"]
    },
    "checked_in_at": { "type": "string" }
  },
  "required": ["guest_key", "display_name", "check_in_status"],
  "rls": {
    "create": { "user_condition": { "role": "admin" } },
    "read": { "user_condition": { "role": "admin" } },
    "update": { "user_condition": { "role": "admin" } },
    "delete": { "user_condition": { "role": "admin" } }
  }
}
